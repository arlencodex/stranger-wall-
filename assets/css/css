:root {
  --bg: #0c0d16;
  --surface: #13141f;
  --surface2: #1a1b2b;
  --border: #252638;
  --gold: #d4a96a;
  --gold-soft: #e8c48e;
  --gold-dim: #8a6a3e;
  --text: #ece7da;
  --muted: #7a7591;
  --muted2: #9e99b8;
  --green: #6bcf7f;
}

* { margin: 0; padding: 0; box-sizing: border-box; }
html, body { height: 100%; }

body {
  background: var(--bg);
  font-family: 'DM Sans', sans-serif;
  color: var(--text);
  overflow-x: hidden;
}

/* ── PAGES ── */
.page { display: none; min-height: 100vh; flex-direction: column; }
.page.active { display: flex; }

/* ══════════════════════════
   DASHBOARD
══════════════════════════ */
#page-dashboard {
  background:
    radial-gradient(ellipse 60% 40% at 70% 20%, rgba(212,169,106,0.07) 0%, transparent 70%),
    radial-gradient(ellipse 40% 50% at 20% 80%, rgba(100,80,180,0.05) 0%, transparent 70%),
    var(--bg);
}

/* NAV */
.dash-nav {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 3rem;
  height: 64px;
  border-bottom: 1px solid var(--border);
  background: rgba(12,13,22,0.9);
  backdrop-filter: blur(20px);
  position: sticky;
  top: 0;
  z-index: 50;
}

.logo {
  display: flex;
  align-items: center;
  gap: 10px;
  font-family: 'Syne', sans-serif;
  font-weight: 800;
  font-size: 1.2rem;
  color: var(--text);
  text-decoration: none;
}

.logo-pulse {
  width: 8px;
  height: 8px;
  background: var(--gold);
  border-radius: 50%;
  animation: pulse 2.4s ease-in-out infinite;
}

@keyframes pulse {
  0%, 100% { opacity: 1; transform: scale(1); }
  50%       { opacity: 0.3; transform: scale(0.6); }
}

.badge {
  font-size: 0.62rem;
  letter-spacing: 1.5px;
  text-transform: uppercase;
  color: var(--gold-dim);
  background: rgba(212,169,106,0.1);
  border: 1px solid rgba(212,169,106,0.2);
  padding: 2px 8px;
  border-radius: 100px;
}

.dash-nav-links {
  display: flex;
  align-items: center;
  gap: 2.5rem;
}

.dash-nav-links a {
  font-size: 0.88rem;
  color: var(--muted);
  text-decoration: none;
  transition: color 0.2s;
}

.dash-nav-links a:hover { color: var(--text); }

/* BUTTONS */
.btn {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 13px 28px;
  border-radius: 100px;
  font-size: 0.93rem;
  font-weight: 500;
  text-decoration: none;
  transition: all 0.2s;
  cursor: pointer;
  border: none;
  font-family: 'DM Sans', sans-serif;
}

.btn-fill { background: var(--gold); color: #0c0d16; }
.btn-fill:hover {
  background: var(--gold-soft);
  transform: translateY(-2px);
  box-shadow: 0 14px 30px rgba(212,169,106,0.28);
}

.btn-ghost {
  background: transparent;
  color: var(--muted2);
  border: 1px solid var(--border);
}
.btn-ghost:hover { border-color: var(--muted); color: var(--text); }

/* HERO */
.dash-hero {
  max-width: 1160px;
  margin: 0 auto;
  padding: 7rem 3rem 4rem;
  display: grid;
  grid-template-columns: 1fr 400px;
  gap: 5rem;
  align-items: center;
}

.eyebrow {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  font-size: 0.75rem;
  letter-spacing: 2.5px;
  text-transform: uppercase;
  color: var(--gold);
  font-weight: 500;
  margin-bottom: 1.4rem;
  opacity: 0;
  animation: fadeUp 0.6s ease 0.1s forwards;
}
.eyebrow::before {
  content: '';
  display: block;
  width: 22px;
  height: 1px;
  background: var(--gold);
}

.dash-hero h1 {
  font-family: 'Syne', sans-serif;
  font-size: clamp(2.8rem, 5vw, 4.4rem);
  font-weight: 700;
  line-height: 1.05;
  letter-spacing: -1.5px;
  margin-bottom: 1.4rem;
  opacity: 0;
  animation: fadeUp 0.6s ease 0.2s forwards;
}
.dash-hero h1 em { font-style: normal; color: var(--gold); }

.dash-hero p {
  font-size: 1.05rem;
  color: var(--muted2);
  line-height: 1.75;
  font-weight: 300;
  max-width: 440px;
  margin-bottom: 2.5rem;
  opacity: 0;
  animation: fadeUp 0.6s ease 0.3s forwards;
}

.hero-btns {
  display: flex;
  gap: 1rem;
  flex-wrap: wrap;
  opacity: 0;
  animation: fadeUp 0.6s ease 0.4s forwards;
}

/* PREVIEW CARD */
.preview-card {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 28px;
  overflow: hidden;
  box-shadow: 0 40px 80px -20px rgba(0,0,0,0.7);
  opacity: 0;
  animation: fadeUp 0.7s ease 0.5s forwards;
}

.preview-topbar {
  padding: 14px 18px;
  border-bottom: 1px solid var(--border);
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.preview-topbar-left {
  display: flex;
  align-items: center;
  gap: 10px;
}

.p-avatar {
  width: 30px;
  height: 30px;
  background: var(--surface2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 0.85rem;
}

.p-title { font-family: 'Syne', sans-serif; font-size: 0.83rem; font-weight: 600; }
.p-sub   { font-size: 0.7rem; color: var(--muted); }

.live-badge {
  display: flex;
  align-items: center;
  gap: 5px;
  font-size: 0.7rem;
  color: var(--green);
  font-weight: 500;
}

.live-dot {
  width: 5px;
  height: 5px;
  background: var(--green);
  border-radius: 50%;
  animation: blink 1.6s infinite;
}

@keyframes blink {
  0%, 100% { opacity: 1; }
  50%       { opacity: 0.2; }
}

.preview-msgs {
  padding: 18px;
  display: flex;
  flex-direction: column;
  gap: 10px;
  min-height: 200px;
}

.pmsg {
  max-width: 78%;
  padding: 10px 14px;
  border-radius: 18px;
  font-size: 0.85rem;
  line-height: 1.5;
}
.pmsg small { display: block; font-size: 0.66rem; opacity: 0.5; margin-top: 3px; }
.pmsg-l { background: var(--surface2); color: var(--text); align-self: flex-start; border-bottom-left-radius: 4px; }
.pmsg-r { background: var(--gold); color: #0c0d16; align-self: flex-end; border-bottom-right-radius: 4px; }

.preview-footer {
  padding: 12px 16px;
  border-top: 1px solid var(--border);
  display: flex;
  gap: 8px;
}

.pfooter-input {
  flex: 1;
  background: var(--surface2);
  border: 1px solid var(--border);
  border-radius: 100px;
  padding: 9px 16px;
  font-size: 0.82rem;
  color: var(--muted);
  font-family: 'DM Sans', sans-serif;
  outline: none;
}

.pfooter-btn {
  width: 36px;
  height: 36px;
  background: var(--gold);
  border: none;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0.7;
}

/* STATS */
.dash-stats {
  max-width: 1160px;
  margin: 0 auto;
  padding: 0 3rem 4rem;
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1px;
  border: 1px solid var(--border);
  background: var(--border);
  border-radius: 20px;
  overflow: hidden;
  opacity: 0;
  animation: fadeUp 0.6s ease 0.7s forwards;
}

.stat-box { background: var(--surface); padding: 2rem; text-align: center; }

.stat-num {
  font-family: 'Syne', sans-serif;
  font-size: 2.6rem;
  font-weight: 700;
  color: var(--gold);
  letter-spacing: -1px;
  display: block;
  margin-bottom: 6px;
}

.stat-lbl {
  font-size: 0.78rem;
  color: var(--muted);
  text-transform: uppercase;
  letter-spacing: 0.8px;
}

/* FEATURES */
.dash-features {
  max-width: 1160px;
  margin: 0 auto;
  padding: 5rem 3rem;
}

.sec-label {
  font-size: 0.73rem;
  letter-spacing: 2.5px;
  text-transform: uppercase;
  color: var(--gold);
  font-weight: 500;
  margin-bottom: 1rem;
}

.sec-heading {
  font-family: 'Syne', sans-serif;
  font-size: 2.2rem;
  font-weight: 700;
  letter-spacing: -0.8px;
  margin-bottom: 3rem;
  max-width: 480px;
}

.feat-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 1.2rem;
}

.feat-card {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 22px;
  padding: 1.8rem 1.4rem;
  transition: all 0.25s;
}
.feat-card:hover {
  border-color: rgba(212,169,106,0.4);
  transform: translateY(-4px);
}

.feat-icon {
  width: 42px;
  height: 42px;
  background: rgba(212,169,106,0.08);
  border: 1px solid rgba(212,169,106,0.15);
  border-radius: 12px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 1.2rem;
  margin-bottom: 1.2rem;
}

.feat-card h3 {
  font-family: 'Syne', sans-serif;
  font-size: 1rem;
  font-weight: 600;
  margin-bottom: 0.5rem;
  letter-spacing: -0.2px;
}

.feat-card p { font-size: 0.84rem; color: var(--muted); line-height: 1.6; font-weight: 300; }

/* QUOTE BAND */
.dash-quote {
  background: var(--surface);
  border-top: 1px solid var(--border);
  border-bottom: 1px solid var(--border);
  padding: 4rem 3rem;
  text-align: center;
  position: relative;
  overflow: hidden;
}

.dash-quote::before {
  content: '"';
  position: absolute;
  top: -3rem;
  left: 50%;
  transform: translateX(-50%);
  font-family: 'Syne', sans-serif;
  font-size: 18rem;
  color: rgba(212,169,106,0.04);
  line-height: 1;
  pointer-events: none;
}

.dash-quote blockquote {
  font-family: 'Syne', sans-serif;
  font-size: clamp(1.4rem, 3vw, 2.2rem);
  font-weight: 600;
  letter-spacing: -0.5px;
  max-width: 640px;
  margin: 0 auto 1rem;
  position: relative;
}

.quote-attr { font-size: 0.82rem; color: var(--muted); }
.quote-attr strong { color: var(--gold); font-weight: 500; }

/* CTA BOTTOM */
.dash-cta-bottom {
  max-width: 1160px;
  margin: 0 auto;
  padding: 6rem 3rem;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}

.dash-cta-bottom h2 {
  font-family: 'Syne', sans-serif;
  font-size: clamp(1.8rem, 4vw, 3rem);
  font-weight: 700;
  letter-spacing: -1px;
  margin-bottom: 1rem;
}

.dash-cta-bottom p {
  color: var(--muted2);
  font-size: 1rem;
  font-weight: 300;
  max-width: 380px;
  margin-bottom: 2.5rem;
  line-height: 1.7;
}

/* FOOTER */
.dash-footer {
  border-top: 1px solid var(--border);
  padding: 2rem 3rem;
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: auto;
}
.dash-footer p { font-size: 0.8rem; color: var(--muted); }

/* ══════════════════════════
   WALL PAGE
══════════════════════════ */
#page-wall {
  background: var(--bg);
  flex-direction: column;
  height: 100vh;
  overflow: hidden;
}

.wall-nav {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 2rem;
  height: 58px;
  border-bottom: 1px solid var(--border);
  background: rgba(12,13,22,0.95);
  backdrop-filter: blur(20px);
  flex-shrink: 0;
  z-index: 50;
}

.wall-nav-left { display: flex; align-items: center; gap: 10px; }

.wall-back {
  background: transparent;
  border: 1px solid var(--border);
  color: var(--muted);
  padding: 6px 14px;
  border-radius: 100px;
  font-size: 0.82rem;
  cursor: pointer;
  font-family: 'DM Sans', sans-serif;
  transition: all 0.2s;
  display: flex;
  align-items: center;
  gap: 6px;
}
.wall-back:hover { border-color: var(--muted); color: var(--text); }

.wall-title {
  font-family: 'Syne', sans-serif;
  font-weight: 700;
  font-size: 1.05rem;
  color: var(--text);
  display: flex;
  align-items: center;
  gap: 8px;
}

.wall-nav-right { display: flex; align-items: center; gap: 12px; }

.online-count {
  display: flex;
  align-items: center;
  gap: 6px;
  font-size: 0.78rem;
  color: var(--green);
  font-weight: 500;
}

.online-dot {
  width: 6px;
  height: 6px;
  background: var(--green);
  border-radius: 50%;
  animation: blink 1.8s infinite;
}

.clear-btn {
  background: transparent;
  border: 1px solid var(--border);
  color: var(--muted);
  padding: 6px 14px;
  border-radius: 100px;
  font-size: 0.8rem;
  cursor: pointer;
  font-family: 'DM Sans', sans-serif;
  transition: all 0.2s;
}
.clear-btn:hover { border-color: #e06060; color: #e06060; }

/* MESSAGES SCROLL AREA */
.messages-wrap {
  flex: 1;
  overflow-y: auto;
  scroll-behavior: smooth;
  padding: 24px 0 10px;
}
.messages-wrap::-webkit-scrollbar { width: 4px; }
.messages-wrap::-webkit-scrollbar-track { background: transparent; }
.messages-wrap::-webkit-scrollbar-thumb { background: var(--border); border-radius: 4px; }

#messages {
  max-width: 820px;
  margin: 0 auto;
  padding: 0 1.5rem;
  display: flex;
  flex-direction: column;
  gap: 0;
}

/* EMPTY STATE */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 5rem 2rem;
  gap: 1rem;
  color: var(--muted);
  text-align: center;
}
.empty-state .big { font-size: 3rem; }
.empty-state h3  { font-family: 'Syne', sans-serif; font-size: 1.2rem; color: var(--text); font-weight: 600; }
.empty-state p   { font-size: 0.88rem; font-weight: 300; }

/* BUBBLES */
.msg {
  max-width: 72%;
  padding: 11px 16px;
  margin: 5px 0;
  border-radius: 20px;
  font-size: 0.9rem;
  line-height: 1.55;
  word-wrap: break-word;
  animation: msgIn 0.25s ease;
}

@keyframes msgIn {
  from { opacity: 0; transform: translateY(8px) scale(0.97); }
  to   { opacity: 1; transform: translateY(0) scale(1); }
}

.msg small {
  display: block;
  font-size: 0.67rem;
  opacity: 0.5;
  margin-top: 4px;
}

.left {
  background: var(--surface2);
  color: var(--text);
  align-self: flex-start;
  border-bottom-left-radius: 5px;
}

.right {
  background: var(--gold);
  color: #0c0d16;
  align-self: flex-end;
  border-bottom-right-radius: 5px;
  margin-left: auto;
}

.sys-msg {
  text-align: center;
  font-size: 0.72rem;
  color: var(--muted);
  padding: 8px 0;
  letter-spacing: 0.5px;
}

/* INPUT BAR */
.input-bar {
  flex-shrink: 0;
  padding: 14px 1.5rem;
  border-top: 1px solid var(--border);
  background: rgba(12,13,22,0.97);
  backdrop-filter: blur(20px);
}

.input-inner {
  max-width: 820px;
  margin: 0 auto;
  display: flex;
  gap: 10px;
  align-items: center;
}

#wall-input {
  flex: 1;
  height: 48px;
  background: var(--surface2);
  border: 1px solid var(--border);
  border-radius: 100px;
  padding: 0 22px;
  font-size: 0.92rem;
  color: var(--text);
  font-family: 'DM Sans', sans-serif;
  outline: none;
  transition: border-color 0.2s;
}
#wall-input:focus  { border-color: rgba(212,169,106,0.4); }
#wall-input::placeholder { color: var(--muted); }

.send-btn {
  width: 48px;
  height: 48px;
  background: var(--gold);
  border: none;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  flex-shrink: 0;
  transition: background 0.2s, transform 0.1s;
}
.send-btn:hover  { background: var(--gold-soft); transform: scale(1.05); }
.send-btn:active { transform: scale(0.96); }
.send-btn svg { width: 16px; height: 16px; color: #0c0d16; }

.char-count {
  font-size: 0.72rem;
  color: var(--muted);
  white-space: nowrap;
  min-width: 40px;
  text-align: right;
}
.char-count.warn { color: #e07a60; }

/* ── SHARED ANIMATIONS ── */
@keyframes fadeUp {
  from { opacity: 0; transform: translateY(18px); }
  to   { opacity: 1; transform: translateY(0); }
}

/* ── RESPONSIVE ── */
@media (max-width: 860px) {
  .dash-hero   { grid-template-columns: 1fr; padding: 4rem 1.5rem 3rem; gap: 3rem; }
  .preview-card { max-width: 420px; }
  .dash-stats  { grid-template-columns: 1fr; margin: 0 1.5rem 3rem; }
  .feat-grid   { grid-template-columns: repeat(2, 1fr); }
  .dash-features, .dash-cta-bottom { padding: 4rem 1.5rem; }
  .dash-quote  { padding: 3rem 1.5rem; }
  .dash-footer { flex-direction: column; gap: 0.8rem; text-align: center; padding: 1.5rem; }
  .dash-nav    { padding: 0 1.2rem; }
}

@media (max-width: 520px) {
  .feat-grid    { grid-template-columns: 1fr; }
  .dash-hero h1 { font-size: 2.8rem; }
}